//| ZEBRA PARABOLIC V5.01 - CORE SAR ENGINE                         |
//| Project: EA PARABOLIC                                            |
//+------------------------------------------------------------------+
#property strict
#property version   "5.01"

#include <Trade/Trade.mqh>
CTrade trade;

//==================== INPUT ====================
input group "=== Parabolic SAR ==="
input double InpSARStep    = 0.02;
input double InpSARMaximum = 0.20;

input group "=== Entry Setting ==="
input int    InpMaxDistancePoints = 200;

input group "=== Trade Setting ==="
input double InpLotSize     = 0.22;
input ulong  InpMagicNumber = 26062026;

input group "=== Display ==="
input bool   InpShowPanel = true;

//==================== ENUM ====================
enum ENUM_ZEBRA_TREND
{
   ZEBRA_TREND_NONE = 0,
   ZEBRA_TREND_BUY  = 1,
   ZEBRA_TREND_SELL = 2
};

enum ENUM_TRADE_STATUS
{
   TRADE_STATUS_NONE      = 0,
   TRADE_STATUS_MANAGED   = 1,
   TRADE_STATUS_FORGOTTEN = 2
};

//==================== STRUCT ====================
struct SAR_DATA
{
   double current;
   double previous;
   double distance_points;
   ENUM_ZEBRA_TREND trend;
};

struct MANAGED_TRADE
{
   ulong ticket;
   ENUM_POSITION_TYPE type;
   ENUM_TRADE_STATUS status;
   bool partial_done;
   double entry_price;
   double lot_initial;
   double lot_current;
   double last_sl;
};

//==================== GLOBAL ====================
int g_SARHandle = INVALID_HANDLE;

double g_SARBuffer[];
SAR_DATA g_SAR;

MANAGED_TRADE g_ManagedTrade;

datetime g_LastBarTime = 0;
bool g_IsNewBar = false;

//+------------------------------------------------------------------+
//| Reset Managed Trade                                              |
//+------------------------------------------------------------------+
void ResetManagedTrade()
{
   g_ManagedTrade.ticket       = 0;
   g_ManagedTrade.type         = POSITION_TYPE_BUY;
   g_ManagedTrade.status       = TRADE_STATUS_NONE;
   g_ManagedTrade.partial_done = false;
   g_ManagedTrade.entry_price  = 0.0;
   g_ManagedTrade.lot_initial  = 0.0;
   g_ManagedTrade.lot_current  = 0.0;
   g_ManagedTrade.last_sl      = 0.0;
}

//+------------------------------------------------------------------+
//| Check New Bar                                                    |
//+------------------------------------------------------------------+
void UpdateNewBar()
{
   datetime currentBarTime = iTime(_Symbol, _Period, 0);

   if(currentBarTime != g_LastBarTime)
   {
      g_IsNewBar = true;
      g_LastBarTime = currentBarTime;
   }
   else
   {
      g_IsNewBar = false;
   }
}

//+------------------------------------------------------------------+
//| Update SAR                                                       |
//+------------------------------------------------------------------+
bool UpdateSAR()
{
   if(g_SARHandle == INVALID_HANDLE)
      return false;

   ArraySetAsSeries(g_SARBuffer, true);

   int copied = CopyBuffer(g_SARHandle, 0, 0, 3, g_SARBuffer);

   if(copied < 3)
      return false;

   g_SAR.current  = g_SARBuffer[0];
   g_SAR.previous = g_SARBuffer[1];

   return true;
}

//+------------------------------------------------------------------+
//| Detect SAR Trend                                                 |
//+------------------------------------------------------------------+
void DetectTrend()
{
   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);

   g_SAR.trend = ZEBRA_TREND_NONE;
   g_SAR.distance_points = 0.0;

   if(g_SAR.current < bid)
   {
      g_SAR.trend = ZEBRA_TREND_BUY;
      g_SAR.distance_points = (bid - g_SAR.current) / _Point;
   }
   else if(g_SAR.current > ask)
   {
      g_SAR.trend = ZEBRA_TREND_SELL;
      g_SAR.distance_points = (g_SAR.current - ask) / _Point;
   }
}

//+------------------------------------------------------------------+
//| Trend To Text                                                    |
//+------------------------------------------------------------------+
string TrendToText(ENUM_ZEBRA_TREND trend)
{
   if(trend == ZEBRA_TREND_BUY)
      return "BUY";

   if(trend == ZEBRA_TREND_SELL)
      return "SELL";

   return "NONE";
}

//+------------------------------------------------------------------+
//| Trade Status To Text                                             |
//+------------------------------------------------------------------+
string TradeStatusToText(ENUM_TRADE_STATUS status)
{
   if(status == TRADE_STATUS_MANAGED)
      return "MANAGED";

   if(status == TRADE_STATUS_FORGOTTEN)
      return "FORGOTTEN";

   return "NONE";
}

//+------------------------------------------------------------------+
//| Count My Positions                                               |
//+------------------------------------------------------------------+
int CountMyPositions()
{
   int count = 0;

   for(int i = PositionsTotal() - 1; i >= 0; i--)
   {
      ulong ticket = PositionGetTicket(i);

      if(ticket == 0)
         continue;

      if(PositionSelectByTicket(ticket))
      {
         string symbol = PositionGetString(POSITION_SYMBOL);
         long magic    = PositionGetInteger(POSITION_MAGIC);

         if(symbol == _Symbol && magic == (long)InpMagicNumber)
            count++;
      }
   }

   return count;
}

//+------------------------------------------------------------------+
//| Draw Panel                                                       |
//+------------------------------------------------------------------+
void DrawPanel()
{
   if(!InpShowPanel)
   {
      Comment("");
      return;
   }

   double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   double spread_points = (ask - bid) / _Point;

   string text = "";

   text += "==============================\n";
   text += "ZEBRA PARABOLIC V5.01\n";
   text += "CORE SAR ENGINE\n";
   text += "==============================\n\n";

   text += "Symbol        : " + _Symbol + "\n";
   text += "Timeframe     : " + EnumToString(_Period) + "\n";
   text += "Magic Number  : " + IntegerToString((int)InpMagicNumber) + "\n\n";

   text += "SAR Step      : " + DoubleToString(InpSARStep, 3) + "\n";
   text += "SAR Maximum   : " + DoubleToString(InpSARMaximum, 3) + "\n";
   text += "SAR Current   : " + DoubleToString(g_SAR.current, _Digits) + "\n";
   text += "SAR Previous  : " + DoubleToString(g_SAR.previous, _Digits) + "\n\n";

   text += "Trend         : " + TrendToText(g_SAR.trend) + "\n";
   text += "Distance      : " + DoubleToString(g_SAR.distance_points, 1) + " points\n";
   text += "Max Distance  : " + IntegerToString(InpMaxDistancePoints) + " points\n\n";

   text += "Bid           : " + DoubleToString(bid, _Digits) + "\n";
   text += "Ask           : " + DoubleToString(ask, _Digits) + "\n";
   text += "Spread        : " + DoubleToString(spread_points, 1) + " points\n\n";

   text += "Managed Status: " + TradeStatusToText(g_ManagedTrade.status) + "\n";
   text += "Managed Ticket: " + IntegerToString((int)g_ManagedTrade.ticket) + "\n";
   text += "Partial Done  : " + (g_ManagedTrade.partial_done ? "YES" : "NO") + "\n";
   text += "My Positions  : " + IntegerToString(CountMyPositions()) + "\n\n";

   text += "New Bar       : " + (g_IsNewBar ? "YES" : "NO") + "\n";
   text += "Bar Time      : " + TimeToString(g_LastBarTime, TIME_DATE | TIME_SECONDS) + "\n";

   Comment(text);
}

//+------------------------------------------------------------------+
//| OnInit                                                           |
//+------------------------------------------------------------------+
int OnInit()
{
   trade.SetExpertMagicNumber(InpMagicNumber);

   ResetManagedTrade();

   g_SARHandle = iSAR(_Symbol, _Period, InpSARStep, InpSARMaximum);

   if(g_SARHandle == INVALID_HANDLE)
   {
      Print("ERROR: Failed to create Parabolic SAR handle.");
      return INIT_FAILED;
   }

   ArraySetAsSeries(g_SARBuffer, true);

   Print("ZEBRA PARABOLIC V5.01 initialized successfully.");
   return INIT_SUCCEEDED;
}

//+------------------------------------------------------------------+
//| OnDeinit                                                         |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   if(g_SARHandle != INVALID_HANDLE)
      IndicatorRelease(g_SARHandle);

   Comment("");

   Print("ZEBRA PARABOLIC V5.01 deinitialized.");
}

//+------------------------------------------------------------------+
//| OnTick                                                           |
//+------------------------------------------------------------------+
void OnTick()
{
   UpdateNewBar();

   if(!UpdateSAR())
   {
      Print("WARNING: Failed to update SAR buffer.");
      return;
   }

   DetectTrend();

   DrawPanel();
}
